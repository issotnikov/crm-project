# ============================================================================
# CRM System — Environment Variables Template
# Copy to .env and fill with real values
# ============================================================================

# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=production                    # development | staging | production
SECRET_KEY=ctpKXpz0
CORS_ORIGINS=https://crm.ai-corp.ru   # comma-separated for production

# ── Database ─────────────────────────────────────────────────────────────────
DB_NAME=crm
DB_USER=crm
DB_PASSWORD=ctpKXpz0

# ── Redis ────────────────────────────────────────────────────────────────────
# REDIS_URL is set in docker-compose, no need to override here

# ── S3 / MinIO ───────────────────────────────────────────────────────────────
S3_ACCESS_KEY=crm_minio_admin
S3_SECRET_KEY=ctpKXpz0

# ── Telegram Bot ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=                   # Get from @BotFather
TELEGRAM_WEBHOOK_URL=                 # Optional: https://crm.company.ru/api/v1/webhooks/telegram

# ── Email (IMAP/SMTP) ────────────────────────────────────────────────────────
IMAP_HOST=imap.company.ru
IMAP_PORT=993
IMAP_USER=sales@company.ru
IMAP_PASSWORD=
SMTP_HOST=smtp.company.ru
SMTP_PORT=587
SMTP_USER=sales@company.ru
SMTP_PASSWORD=

# ── IP-Телефония (Mango Office / UIS) ────────────────────────────────────────
PHONE_PROVIDER=mango                  # mango | uis | megaplan
PHONE_API_KEY=
PHONE_API_SECRET=
PHONE_DOMAIN=                         # e.g. mprefix.uiscom.ru

# ── Web Form ─────────────────────────────────────────────────────────────────
WEBFORM_API_KEY=                      # API key for website form

# ── reCAPTCHA v3 ─────────────────────────────────────────────────────────────
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# ── Monitoring (optional) ────────────────────────────────────────────────────
GRAFANA_PASSWORD=ctpKXpz0
